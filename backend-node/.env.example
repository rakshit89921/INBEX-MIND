# INBEX Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── App ────────────────────────────────────
APP_NAME=INBEX
PORT=3000
DEBUG=false

# ── JWT ────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-string-32-chars-min
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── OpenRouter (REQUIRED for AI features) ─
# Get your free key at: https://openrouter.ai/keys
# One key gives access to ALL models below (NVIDIA, OpenAI, Google, Qwen)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=INBEX

# ── AI Model Assignments (optional - defaults shown) ─
# These are all FREE tier models on OpenRouter
MODEL_SUMMARIZE=google/gemma-3-27b-it:free
MODEL_SMART_REPLY=nvidia/nemotron-super-49b-v1:free
MODEL_COMPOSE=openai/gpt-4o:free
MODEL_CLASSIFY=qwen/qwen3-coder-480b-a35b:free
MODEL_CHAT=qwen/qwen3-coder-480b-a35b:free
MODEL_PRIORITY_SCORE=nvidia/nemotron-super-49b-v1:free
MODEL_INSIGHTS=google/gemma-3-27b-it:free

# ── Groq (legacy fallback) ─────────────────
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Google OAuth (Gmail Integration) ───────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── Resend (OTP Emails) ────────────────────
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=INBEX <onboarding@resend.dev>
